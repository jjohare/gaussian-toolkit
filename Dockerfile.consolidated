# =============================================================================
# LichtFeld Studio / Gaussian Toolkit — Consolidated Dockerfile
# Target: Dual RTX 6000 Ada (2x48GB VRAM), 251GB RAM, Threadripper PRO 48-core
# Base: CUDA 12.8.1 devel on Ubuntu 24.04
# =============================================================================

FROM nvidia/cuda:12.8.1-devel-ubuntu24.04 AS base

ARG DEBIAN_FRONTEND=noninteractive
ARG MAKEFLAGS="-j$(nproc)"

# ---------------------------------------------------------------------------
# PHASE 1: System packages
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        software-properties-common ca-certificates gnupg lsb-release \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build nasm git curl wget ffmpeg imagemagick \
        python3.11 python3.11-venv python3.11-dev \
        python3.12 python3.12-venv python3.12-dev python3-pip \
        libgl1 libglib2.0-0 libsm6 libxext6 libxrender1 \
        autoconf autoconf-archive automake libtool pkg-config \
        libeigen3-dev libceres-dev libsuitesparse-dev libcgal-dev \
        libgoogle-glog-dev libglew-dev libsqlite3-dev \
        libboost-all-dev libflann-dev libfreeimage-dev \
        libopenimageio-dev openimageio-tools libopencv-dev \
        x11vnc xvfb fluxbox \
        supervisor nginx \
        jq zip unzip \
    && rm -rf /var/lib/apt/lists/*

# Make python3.12 the default python3
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 2 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# ---------------------------------------------------------------------------
# PHASE 2: Node.js 23 (for Claude Code tooling)
# ---------------------------------------------------------------------------
RUN curl -fsSL https://nodejs.org/dist/v23.11.1/node-v23.11.1-linux-x64.tar.xz \
        | tar -xJ -C /usr/local --strip-components=1 \
    && npm install -g @anthropic-ai/claude-code

# ttyd — web terminal over HTTP
RUN curl -fsSL https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.x86_64 \
        -o /usr/local/bin/ttyd && chmod +x /usr/local/bin/ttyd

# ---------------------------------------------------------------------------
# PHASE 3: METIS + GKlib from source (required by COLMAP via Ceres/SuiteSparse)
# ---------------------------------------------------------------------------
RUN cd /tmp && \
    curl -sL https://github.com/KarypisLab/METIS/archive/refs/tags/v5.2.1.tar.gz | tar xz && \
    cd METIS-5.2.1 && \
    git clone --depth 1 https://github.com/KarypisLab/GKlib.git && \
    # Build GKlib static
    mkdir -p GKlib/build && cd GKlib/build && \
    cmake .. -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_FLAGS="-fPIC" -DBUILD_SHARED_LIBS=OFF && \
    make -j$(nproc) GKlib && make install && \
    # Build METIS static
    cd /tmp/METIS-5.2.1 && \
    mkdir -p build/xinclude && \
    echo "#define IDXTYPEWIDTH 32" > build/xinclude/metis.h && \
    echo "#define REALTYPEWIDTH 32" >> build/xinclude/metis.h && \
    cat include/metis.h >> build/xinclude/metis.h && \
    cp include/CMakeLists.txt build/xinclude && \
    cd build && \
    cmake /tmp/METIS-5.2.1 -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DGKLIB_PATH=/tmp/METIS-5.2.1/GKlib -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_FLAGS="-fPIC" && \
    make -j$(nproc) metis && \
    cp libmetis/libmetis.a /usr/local/lib/ && \
    cp /tmp/METIS-5.2.1/build/xinclude/metis.h /usr/local/include/ && \
    # Create METIS cmake config
    mkdir -p /usr/local/lib/cmake/metis && \
    printf 'if(NOT TARGET METIS::METIS)\n\
  add_library(METIS::METIS STATIC IMPORTED)\n\
  set_target_properties(METIS::METIS PROPERTIES\n\
    IMPORTED_LOCATION "/usr/local/lib/libmetis.a"\n\
    INTERFACE_INCLUDE_DIRECTORIES "/usr/local/include"\n\
    INTERFACE_LINK_LIBRARIES "/usr/local/lib/libGKlib.a;m")\n\
endif()\n\
set(METIS_FOUND TRUE)\n' > /usr/local/lib/cmake/metis/metis-config.cmake && \
    ldconfig && \
    rm -rf /tmp/METIS-5.2.1

# ---------------------------------------------------------------------------
# PHASE 4: COLMAP from source (headless, CUDA sm_89 for Ada GPUs)
# ---------------------------------------------------------------------------
RUN git clone --depth 1 https://github.com/colmap/colmap.git /tmp/colmap && \
    cmake -B /tmp/colmap/build -S /tmp/colmap \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_CUDA_ARCHITECTURES="89" \
        -DGUI_ENABLED=OFF \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_PREFIX_PATH=/usr/local \
        -G Ninja && \
    cmake --build /tmp/colmap/build -- -j$(nproc) && \
    cmake --install /tmp/colmap/build && \
    rm -rf /tmp/colmap

# ---------------------------------------------------------------------------
# PHASE 5: vcpkg + LichtFeld Studio from source
# ---------------------------------------------------------------------------
RUN git clone https://github.com/microsoft/vcpkg.git /opt/vcpkg && \
    /opt/vcpkg/bootstrap-vcpkg.sh -disableMetrics

ENV VCPKG_ROOT=/opt/vcpkg
ENV PATH="/opt/vcpkg:${PATH}"

RUN git clone --recursive https://github.com/jjohare/gaussian-toolkit.git /opt/gaussian-toolkit && \
    cd /opt/gaussian-toolkit && \
    git checkout gaussian-toolkit && \
    cmake -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_TOOLCHAIN_FILE=/opt/vcpkg/scripts/buildsystems/vcpkg.cmake \
        -DCMAKE_CUDA_ARCHITECTURES="89" \
        -G Ninja && \
    cmake --build build -- -j$(nproc) || true
    # Binary links even if stubgen fails — vcpkg USD python bindings
    # may fail on stubgen but the core library is still usable

# ---------------------------------------------------------------------------
# PHASE 6: Blender 5.0.1
# ---------------------------------------------------------------------------
RUN mkdir -p /opt/blender && \
    curl -fsSL https://download.blender.org/release/Blender5.0/blender-5.0.1-linux-x64.tar.xz \
        | tar -xJ -C /opt/blender --strip-components=1 && \
    ln -sf /opt/blender/blender /usr/local/bin/blender

# ---------------------------------------------------------------------------
# PHASE 7: ComfyUI
# ---------------------------------------------------------------------------
RUN git clone https://github.com/comfyanonymous/ComfyUI.git /opt/comfyui && \
    cd /opt/comfyui && \
    pip3 install --break-system-packages -r requirements.txt && \
    pip3 install --break-system-packages \
        torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu128

# Ensure all ComfyUI deps are also on python3.12 path
RUN /usr/bin/python3.12 -m pip install --break-system-packages \
        -r /opt/comfyui/requirements.txt

# ComfyUI custom nodes
RUN cd /opt/comfyui/custom_nodes && \
    git clone https://github.com/ltdrdata/ComfyUI-Manager.git && \
    git clone https://github.com/peteromallet/comfyui-sam3dobjects.git && \
    # Hunyuan3D v2 ComfyUI integration
    git clone https://github.com/tencent/Hunyuan3D-2.git hunyuan3d-2 || true

# ---------------------------------------------------------------------------
# PHASE 8: Python pipeline dependencies
# ---------------------------------------------------------------------------
# Note: sam2 pulls antlr4/iopath which fail on Python 3.12.
# Install sam2 from git with relaxed deps, skip open3d (no 3.12 wheels).
RUN pip3 install --break-system-packages --ignore-installed \
        trimesh xatlas pymeshfix fast-simplification scikit-image \
        pillow piexif av yt-dlp huggingface_hub requests aiohttp flask sqlalchemy \
        filelock tqdm pyyaml blake3 kornia spandrel einops \
        plyfile numpy scipy opencv-python-headless \
        segment-anything psutil \
    && pip3 install --break-system-packages \
        "sam-2==1.1.0" || pip3 install --break-system-packages \
        "segment-anything-2" || echo "SAM2 pip install skipped — using ComfyUI SAM2 nodes instead" \
    && pip3 install --break-system-packages \
        sam3 || pip3 install --break-system-packages \
        "sam3 @ git+https://github.com/facebookresearch/sam3.git" \
        || echo "SAM3 pip install skipped — text-prompted segmentation unavailable"

# USD requires python3.11 — isolated venv
RUN python3.11 -m venv /opt/venv-usd && \
    /opt/venv-usd/bin/pip install usd-core numpy trimesh

# ---------------------------------------------------------------------------
# PHASE 9: Pipeline code from gaussian-toolkit repo
# ---------------------------------------------------------------------------
# Already cloned in Phase 5; create convenient symlinks
RUN ln -sf /opt/gaussian-toolkit/src/pipeline /opt/pipeline && \
    ln -sf /opt/gaussian-toolkit/scripts /opt/scripts && \
    ln -sf /opt/gaussian-toolkit/research /opt/research

# ---------------------------------------------------------------------------
# PHASE 10: Minimal Flask web interface (placeholder for web-interface agent)
# ---------------------------------------------------------------------------
# Web interface from the gaussian-toolkit repo (cloned in Phase 5)
RUN ln -sf /opt/gaussian-toolkit/src/web /opt/web-interface

# ---------------------------------------------------------------------------
# PHASE 11: Model directory structure
# ---------------------------------------------------------------------------
RUN mkdir -p /opt/models/diffusion_models \
             /opt/models/text_encoders \
             /opt/models/vae \
             /opt/models/loras \
             /opt/models/trellis2 \
             /opt/models/sam3d \
             /opt/models/sam2 \
             /opt/models/grounding-dino \
             /opt/models/sams \
             /opt/models/hunyuan3d \
    && mkdir -p /opt/output \
    && mkdir -p /models-staging

# ---------------------------------------------------------------------------
# PHASE 12: VNC + supervisord configuration
# ---------------------------------------------------------------------------
RUN mkdir -p /var/log/supervisor /var/run/supervisor /root/.fluxbox

COPY docker/supervisord.conf /etc/supervisor/conf.d/gaussian-toolkit.conf

# Claude Code agent instructions for in-container use
COPY CLAUDE_CONTAINER.md /opt/gaussian-toolkit/CLAUDE.md

# ---------------------------------------------------------------------------
# PHASE 13: Entrypoint
# ---------------------------------------------------------------------------
COPY docker/entrypoint.sh /opt/entrypoint.sh
RUN chmod +x /opt/entrypoint.sh

# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics
ENV CUDA_HOME=/usr/local/cuda
ENV DISPLAY=:1
ENV PATH="/opt/gaussian-toolkit/build:/opt/venv-usd/bin:${PATH}"
ENV LD_LIBRARY_PATH="/usr/local/cuda/lib64:/usr/local/lib:${LD_LIBRARY_PATH}"
ENV VCPKG_ROOT=/opt/vcpkg

# ---------------------------------------------------------------------------
# Exposed ports
# ---------------------------------------------------------------------------
# 7860  = Web interface (Flask)
# 7681  = Web terminal (ttyd)
# 8188  = ComfyUI
# 45677 = LichtFeld Studio (if applicable)
# 5901  = VNC
EXPOSE 7860 7681 8188 45677 5901

WORKDIR /opt/gaussian-toolkit

ENTRYPOINT ["/opt/entrypoint.sh"]
